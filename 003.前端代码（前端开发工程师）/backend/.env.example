# 每日记账 - 后端环境配置（示例）
# 复制此文件为 .env 并修改配置
# ==========================================

PORT=3000

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=daily_expense

JWT_SECRET=change_me_to_a_random_secret_key_in_production
JWT_EXPIRES_IN=24h
JWT_REMEMBER_EXPIRES_IN=7d

LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

CLIENT_URL=http://localhost:5173
