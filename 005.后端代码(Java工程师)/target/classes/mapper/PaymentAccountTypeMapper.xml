<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.financemanager.mapper.PaymentAccountTypeMapper">

    <resultMap id="BaseResultMap" type="com.financemanager.entity.PaymentAccountType">
        <id column="id" property="id"/>
        <result column="code" property="code"/>
        <result column="name" property="name"/>
        <result column="icon" property="icon"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="is_active" property="isActive"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <select id="findAllEnabled" resultMap="BaseResultMap">
        SELECT * FROM payment_account_types WHERE is_active = TRUE ORDER BY sort_order ASC
    </select>

    <select id="findById" resultMap="BaseResultMap">
        SELECT * FROM payment_account_types WHERE id = #{id}
    </select>

</mapper>
